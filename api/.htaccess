<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Permite que el Token (Authorization) llegue a PHP
    # Sin esto, $_SERVER['HTTP_AUTHORIZATION'] estará vacío en PHP
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

    # 2. No hagas nada más si el archivo existe
    # Esto permite que chollos.php se ejecute normalmente
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
</IfModule>
